{
  "name": "openmindlearn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @openmindlearn/backend --filter @openmindlearn/frontend dev",
    "dev:desktop": "pnpm --parallel --filter @openmindlearn/backend --filter @openmindlearn/frontend --filter @openmindlearn/desktop dev",
    "build": "pnpm -r build",
    "build:desktop": "pnpm build && pnpm -C packages/desktop build:mac",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
